# Famly Budget App - Environment Variables
# Copy this file to .env and fill in your values

# Database Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=famly
POSTGRES_USER=famly
POSTGRES_PASSWORD=famly

# pgAdmin credentials (for local development)
PGADMIN_DEFAULT_EMAIL=admin@famly.local
PGADMIN_DEFAULT_PASSWORD=famly

# JWT Configuration
# IMPORTANT: Use a strong, unique secret in production!
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRES_IN=24h

# Frontend API URL (used during build)
NEXT_PUBLIC_API_URL=http://localhost:8080/api
